{
  "name": "kpcrop/synkrop-prestashop",
  "description": "Plugin PrestaShop para sincronizar productos, precios y stock desde Bsale",
  "version": "1.0.0",
  "type": "prestashop-module",
  "license": "proprietary",
  "authors": [
    { "name": "kpcrop-latam", "email": "dev@kpcrop.com" }
  ],
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "squizlabs/php_codesniffer": "^3.7"
  },
  "autoload": {
    "psr-4": {
      "Kpcrop\\Synkrop\\": "synkrop/classes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Kpcrop\\Synkrop\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --testdox",
    "lint": "phpcs --standard=PSR12 synkrop/classes/"
  },
  "config": {
    "optimize-autoloader": true,
    "platform": {
      "php": "8.1"
    }
  }
}

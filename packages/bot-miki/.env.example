NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

DATABASE_URL=postgresql://botmiki:botmiki_dev@localhost:5432/botmiki
REDIS_URL=redis://localhost:6379

# Minimo 32 chars — genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_clave_de_al_menos_32_caracteres_en_produccion

# OBLIGATORIO (min 32 chars). Protege las rutas /v1/admin/*. Sin default: el proceso
# aborta si no esta seteado. En prod (Railway) debe existir ANTES de arrancar.
ADMIN_KEY=cambia_esto_por_una_clave_admin_de_al_menos_32_caracteres

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Limite de requests a Bsale por segundo (conservador hasta confirmar el real)
BSALE_RATE_LIMIT_RPS=10

# OBLIGATORIO (min 32 chars). Cifra tenant_stores.bsale_access_token en reposo
# (#107). Llave dedicada — NO reusar JWT_SECRET/ADMIN_KEY. Genera una con:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=cambia_esto_por_una_clave_de_al_menos_32_caracteres_en_produccion
